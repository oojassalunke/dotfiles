#!/usr/bin/env bash

darwin_info() {
    echo "Running on macOS"
    # Add your macOS-specific logic here
}

debian_info() {
    echo "Running on Debian/Ubuntu"
    # Add your Debian/Ubuntu-specific logic here
}

raspberry_info() {
    echo "Running on Raspberry Pi"
    # Add your Raspberry Pi-specific logic here
}

default_info() {
    echo "Running on an unrecognized OS"
    # Add your fallback logic here
}

detect_os() {
    # macOS
    if [[ "$(uname -s)" == "Darwin" ]]; then
        ./darwin-splash
        return
    fi

    # Raspberry Pi: check before generic Debian, since a Pi usually runs
    # Debian/Raspberry Pi OS and would otherwise match the Debian branch.
    if grep -qi "raspberry pi" /proc/device-tree/model 2>/dev/null \
        || grep -qi "raspbian" /etc/os-release 2>/dev/null; then
        ./raspberry-splash
        return
    fi

    if [[ "$(uname -s)" == "Linux" ]]; then
        ./linux-splash
        return
    fi

    # Fallback
    uname -a
}

detect_os
